# ============================================================
# SORTT — MOBILE APP ENVIRONMENT VARIABLES (EXAMPLE)
# Copy to .env and fill values. Never commit secrets.
# ============================================================

# --- CLERK ---
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- BACKEND URL ---
EXPO_PUBLIC_API_URL=http://192.168.1.100:8080/api

# --- MAPS ---
EXPO_PUBLIC_OLA_MAPS_API_KEY=
EXPO_PUBLIC_MAP_PROVIDER=ola
EXPO_PUBLIC_MAP_RENDERING_AVAILABLE=true

# --- PROVIDER SWITCHES ---
EXPO_PUBLIC_REALTIME_PROVIDER=ably

# --- ABLY TOKEN AUTH ---
# Mobile must authenticate through backend token endpoint.
# Do NOT add EXPO_PUBLIC_ABLY_KEY.
# Do NOT use ${EXPO_PUBLIC_API_URL} here — Expo SDK 49+ expands variables,
# which causes a double /api path. Set explicitly or omit (auto-constructed from EXPO_PUBLIC_API_URL).
# EXPO_PUBLIC_ABLY_AUTH_URL=http://YOUR_LOCAL_IP:8080/api/realtime/token
