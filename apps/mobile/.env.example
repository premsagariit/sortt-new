# ============================================================
# SORTT — MOBILE APP ENVIRONMENT VARIABLES (EXAMPLE)
# Copy to .env and fill values. Never commit secrets.
# ============================================================

# --- CLERK ---
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- BACKEND URL ---
EXPO_PUBLIC_API_URL=http://192.168.1.100:8080/api

# --- MAPS ---
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_MAP_PROVIDER=google

# --- PROVIDER SWITCHES ---
EXPO_PUBLIC_REALTIME_PROVIDER=ably

# --- ABLY TOKEN AUTH ---
# Mobile must authenticate through backend token endpoint.
# Do NOT add EXPO_PUBLIC_ABLY_KEY.
EXPO_PUBLIC_ABLY_AUTH_URL=${EXPO_PUBLIC_API_URL}/api/realtime/token
