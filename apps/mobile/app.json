{
  "expo": {
    "name": "Sortt",
    "slug": "sortt-mobile",
    "scheme": "sortt",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1C2E4A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Sortt uses the camera to photograph your scrap pile and weighing scale.",
        "NSPhotoLibraryUsageDescription": "Sortt needs photo library access to attach images to your listing."
      }
    },
    "android": {
      "package": "com.sagar.sortt",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1C2E4A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Sortt needs photo library access to attach images to your listing.",
          "cameraPermission": "Sortt uses the camera to photograph your scrap pile and weighing scale."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "90966a13-507b-4386-9e20-4d7e18fdb9da"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/90966a13-507b-4386-9e20-4d7e18fdb9da"
    }
  }
}
