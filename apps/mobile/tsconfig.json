{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@sortt/maps": ["../../packages/maps/src/index.ts"],
      "@sortt/realtime": ["../../packages/realtime/src/index.ts"],
      "@sortt/auth": ["../../packages/auth/src/index.ts"],
      "@sortt/storage": ["../../packages/storage/src/index.ts"],
      "@sortt/analysis": ["../../packages/analysis/src/index.ts"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "constants/**/*.ts",
    "lib/**/*.ts",
    "store/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
