{
  "name": "sortt-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Sortt scrap marketplace — pnpm monorepo",
  "scripts": {
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:mobile:clean": "pnpm --filter mobile dev -- --clear",
    "dev:web": "pnpm --filter web dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "install:all": "pnpm install",
    "start": "node backend/dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "expo": "~54.0.33"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}