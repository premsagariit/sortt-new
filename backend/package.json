{
    "name":  "backend",
    "version":  "1.0.0",
    "private":  true,
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "dev":  "ts-node-dev --respawn --transpile-only src/index.ts",
                    "build":  "tsc --project tsconfig.json",
                    "start":  "node dist/index.js",
                    "type-check":  "tsc --noEmit",
                    "lint":  "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern"
                },
    "dependencies":  {
                         "jose":  "^5.9.6",
                         "@google/generative-ai":  "^0.24.1",
                         "@pdf-lib/fontkit":  "^1.1.1",
                         "@sentry/node":  "^10.42.0",
                         "@sentry/profiling-node":  "^10.42.0",
                         "@sortt/analysis":  "workspace:*",
                         "@sortt/maps":  "workspace:*",
                         "@sortt/realtime":  "workspace:*",
                         "@sortt/storage":  "workspace:*",
                         "@sparticuz/chromium":  "^143.0.4",

                         "@upstash/ratelimit":  "^1.2.1",
                         "@upstash/redis":  "^1.28.4",
                         "ably":  "^2.0.0",
                         "axios":  "^1.7.2",
                         "bcryptjs":  "^3.0.3",
                         "cors":  "^2.8.5",
                         "dotenv":  "^17.3.1",
                         "etag":  "^1.8.1",
                         "expo-server-sdk":  "^3.10.0",
                         "express":  "^4.19.2",
                         "helmet":  "^7.1.0",

                         "multer":  "^2.1.1",
                         "node-cron":  "^4.2.1",
                         "pdf-lib":  "^1.17.1",
                         "pg":  "^8.20.0",
                         "puppeteer-core":  "^24.40.0",
                         "sanitize-html":  "^2.13.0",
                         "sharp":  "^0.33.4"
                     },
    "devDependencies":  {
                            "@types/bcryptjs":  "^3.0.0",
                            "@types/cors":  "^2.8.17",
                            "@types/etag":  "^1.8.4",
                            "@types/express":  "^4.17.21",
                            "@types/multer":  "^2.1.0",
                            "@types/node":  "^20.14.9",
                            "@types/node-cron":  "^3.0.11",
                            "@types/pg":  "^8",
                            "@types/sanitize-html":  "^2.11.0",
                            "@typescript-eslint/eslint-plugin":  "^7.16.0",
                            "@typescript-eslint/parser":  "^7.16.0",
                            "eslint":  "^8.57.0",
                            "ts-node-dev":  "^2.0.0",
                            "typescript":  "^5.5.3"
                        },
    "eslintConfig":  {
                         "parser":  "@typescript-eslint/parser",
                         "parserOptions":  {
                                               "sourceType":  "module"
                                           },
                         "ignorePatterns":  [
                                                "dist/",
                                                "dist-test/",
                                                "node_modules/"
                                            ]
                     }
}
