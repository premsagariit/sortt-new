# ============================================================
# SORTT — .antigravityignore
# Prevents agents from burning context window quota on
# auto-generated, vendored, or irrelevant directories.
# ============================================================

# --- Package managers & vendored dependencies ---
node_modules/
.pnp/
.pnp.js
.yarn/cache/
.yarn/unplugged/

# --- Build outputs ---
dist/
build/
out/
.next/
.turbo/
.vercel/

# --- Expo / React Native build artifacts ---
.expo/
.expo-shared/
ios/Pods/
ios/build/
ios/DerivedData/
android/app/build/
android/.gradle/
android/local.properties

# --- Python (price scraper agent) ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# --- Test coverage & snapshots ---
coverage/
.nyc_output/
__snapshots__/

# --- Git internals ---
.git/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Environment files (NEVER read by agents — secrets live here) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# --- OS & editor noise ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

