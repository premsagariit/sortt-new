# ============================================================
# .env.example — ALL environment variable keys for this project
# Copy to .env and fill in values. NEVER commit .env to git.
# See MEMORY.md §5 for full documentation on each variable.
# ============================================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_WEBHOOK_SECRET=
SUPABASE_HOOK_SECRET=

# --- Custom Backend ---
JWT_SECRET=
OTP_HMAC_SECRET=

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AI (Gemini) ---
GEMINI_API_KEY=

# --- Meta WhatsApp Cloud API ---
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_OTP_TEMPLATE_NAME=
META_API_VERSION=

# --- Maps ---
GOOGLE_MAPS_API_KEY=
MAP_PROVIDER=

# --- Push Notifications ---
EXPO_ACCESS_TOKEN=

# --- Provider Switches ---
REALTIME_PROVIDER=

# --- Python Price Scraper ---
GEMINI_API_KEY_SCRAPER=
PRICE_SCRAPER_WEBHOOK_URL=

# --- Web / Admin (Next.js) ---
# NEXT_PUBLIC_SUPABASE_URL=      (mirrors SUPABASE_URL — safe for client bundle)
# NEXT_PUBLIC_SUPABASE_ANON_KEY= (mirrors SUPABASE_ANON_KEY — safe for client bundle)
# DO NOT add SUPABASE_SERVICE_KEY to any NEXT_PUBLIC_* var — server-only (V12)

# --- CORS ---
ALLOWED_ORIGINS=

# --- Admin Security ---
ADMIN_IP_ALLOWLIST=
