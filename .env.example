# ============================================================
# .env.example — ALL environment variable keys for this project
# Copy to .env and fill in values. NEVER commit .env to git.
# See MEMORY.md §5 for full documentation on each variable.
# ============================================================
# --- Custom Backend ---
JWT_SECRET=
OTP_HMAC_SECRET=

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AI (Gemini) ---
GEMINI_API_KEY=

# --- Meta WhatsApp Cloud API ---
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_OTP_TEMPLATE_NAME=
META_API_VERSION=

# --- Maps ---
GOOGLE_MAPS_API_KEY=
MAP_PROVIDER=

# --- Push Notifications ---
EXPO_ACCESS_TOKEN=

# --- Provider Switches ---
REALTIME_PROVIDER=
STORAGE_PROVIDER=r2

# --- Cloudflare R2 Storage ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Python Price Scraper ---
GEMINI_API_KEY_SCRAPER=
PRICE_SCRAPER_WEBHOOK_URL=

# --- CORS ---
ALLOWED_ORIGINS=

# --- Admin Security ---
ADMIN_IP_ALLOWLIST=

# --- Ably ---
ABLY_API_KEY =
